        {cards.map((_,i)=><div key={i} onClick={()=>{setIdx(i);setFlipped(false);}} style={{width:8,height:8,borderRadius:"50%",background:i===idx?T.amber:known.has(i)?T.green:T.border2,cursor:"pointer",transition:"background .2s"}}/>)}
      </div>
    </div>}
    {!loading&&cards.length===0&&<div style={{textAlign:"center",padding:"40px 0",color:T.muted2}}>
