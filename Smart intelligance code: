      </div>
      <div style={{display:"flex",gap:8,marginTop:12}}>
        <button onClick={()=>{setIdx(i=>Math.max(0,i-1));setFlipped(false);}} disabled={idx===0} style={{flex:1,padding:"9px",background:T.bg2,border:`1px solid ${T.border}`,borderRadius:7,color:T.muted,fontSize:13}}>← Prev</button>
        <button onClick={()=>{setKnown(s=>{const n=new Set(s);n.has(idx)?n.delete(idx):n.add(idx);return n;});}} style={{flex:1,padding:"9px",background:known.has(idx)?T.bg3:"transparent",border:`1px solid ${known.has(idx)?T.green:T.border}`,borderRadius:7,color:known.has(idx)?T.green:T.muted,fontSize:13}}>{known.has(idx)?"✓ Known":"Mark known"}</button>
