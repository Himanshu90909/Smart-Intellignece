function FlashPane() {
  const [topic,setTopic]=useState("");
  const [cards,setCards]=useState([]);
  const [idx,setIdx]=useState(0);
  const [flipped,setFlipped]=useState(false);
  const [loading,setLoading]=useState(false);
  const [known,setKnown]=useState(new Set());
  const gen=async()=>{
    if(!topic.trim()||loading) return;
    setLoading(true);setCards([]);setIdx(0);setFlipped(false);setKnown(new Set());
    try{
      const raw=await callAI(`Create exactly 8 flashcards. Return ONLY a JSON array:\n[{"front":"Question","back":"Answer"}]\nNo markdown, only JSON.`,[{role:"user",content:topic}]);
      setCards(JSON.parse(raw.replace(/```json|```/g,"").trim()));
    }catch{setCards([{front:"Error",back:"Try again."}]);}
    finally{setLoading(false);}
  };
  const card=cards[idx];
  const pct=cards.length?Math.round((known.size/cards.length)*100):0;
  return <div style={{display:"flex",flexDirection:"column",height:"100%"}}>
    <div style={{display:"flex",gap:8,marginBottom:14}}>
      <input value={topic} onChange={e=>setTopic(e.target.value)} onKeyDown={e=>e.key==="Enter"&&gen()} placeholder="Topic for flashcards…" style={{flex:1,fontSize:14}}/>
