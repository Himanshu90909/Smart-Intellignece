/* ─── AI CALL ───────────────────────────────────────────────────────────── */
async function callAI(system, messages, opts = {}) {
  const body = {
    model: "claude-sonnet-4-20250514",
    max_tokens: 1000,
    system,
    messages,
  };
  if (opts.webSearch) body.tools = [{ type:"web_search_20250305", name:"web_search" }];
  const r = await fetch("https://api.anthropic.com/v1/messages", {
    method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify(body),
  });
  const d = await r.json();
  return d.content?.filter(b=>b.type==="text").map(b=>b.text).join("\n") || "No response.";
}
/* ─── MARKDOWN ──────────────────────────────────────────────────────────── */
function Md({ text, small }) {
  const fs = small ? 13 : 14;
  const inline = t => {
    const parts = t.split(/(\*\*[^*]+\*\*|`[^`]+`|\*[^*]+\*)/g);
    return parts.map((p,i) => {
      if (p.startsWith("**")&&p.endsWith("**")) return <strong key={i} style={{fontWeight:600,color:T.cream}}>{p.slice(2,-2)}</strong>;
      if (p.startsWith("`")&&p.endsWith("`")) return <code key={i} style={{fontFamily:"'JetBrains Mono',monospace",fontSize:11,padding:"1px 5px",background:T.bg3,borderRadius:3,color:T.yellow,border:`0.5px solid ${T.border2}`}}>{p.slice(1,-1)}</code>;
      if (p.startsWith("*")&&p.endsWith("*")) return <em key={i} style={{color:T.muted}}>{p.slice(1,-1)}</em>;
      return p;
    });
  };
  return <div style={{fontSize:fs,lineHeight:1.8,color:T.cream}}>
    {text.split("\n").map((ln,i)=>{
      if(ln.startsWith("# ")) return <h2 key={i} style={{fontSize:17,fontWeight:600,fontFamily:"'Crimson Pro',serif",margin:"16px 0 8px",color:T.amber,borderBottom:`1px solid ${T.border}`,paddingBottom:6}}>{inline(ln.slice(2))}</h2>;
      if(ln.startsWith("## ")) return <h3 key={i} style={{fontSize:15,fontWeight:600,fontFamily:"'Crimson Pro',serif",margin:"14px 0 5px",color:T.cream}}>{inline(ln.slice(3))}</h3>;
      if(ln.startsWith("### ")) return <p key={i} style={{fontWeight:500,margin:"10px 0 3px",color:T.muted,fontSize:12,textTransform:"uppercase",letterSpacing:"0.07em"}}>{inline(ln.slice(4))}</p>;
      if(ln.match(/^[-•]\s/)) return <div key={i} style={{display:"flex",gap:8,margin:"3px 0"}}><span style={{color:T.amber,flexShrink:0,marginTop:2}}>›</span><span>{inline(ln.slice(2))}</span></div>;
      if(ln.match(/^\d+\.\s/)){const n=ln.match(/^(\d+)/)[1];return<div key={i} style={{display:"flex",gap:8,margin:"3px 0"}}><span style={{color:T.muted,minWidth:18,flexShrink:0,fontFamily:"'JetBrains Mono',monospace",fontSize:11}}>{n}.</span><span>{inline(ln.replace(/^\d+\.\s/,""))}</span></div>;}
      if(ln.startsWith("★")||ln.startsWith("Q")||ln.startsWith("A")) return <p key={i} style={{margin:"4px 0",color:ln.startsWith("A")?T.green:T.cream}}>{inline(ln)}</p>;
      if(ln.startsWith("---")) return <hr key={i} style={{border:"none",borderTop:`1px solid ${T.border}`,margin:"12px 0"}}/>;
      if(!ln.trim()) return <div key={i} style={{height:7}}/>;
      return <p key={i} style={{margin:"3px 0"}}>{inline(ln)}</p>;
    })}
  </div>;
}
