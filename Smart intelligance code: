  const SMODES=[
    {id:"extract",l:"Extract Text",s:"Extract all text from this image exactly as it appears. Preserve formatting, bullet points and structure."},
    {id:"explain",l:"Explain Content",s:"Analyze and explain everything in this image in detail. If it's a diagram, explain what it shows. If it's text, summarize and explain."},
    {id:"notes",l:"Make Notes",s:"Convert the content of this image into organized study notes with bullet points, key terms bolded, and a summary."},
    {id:"questions",l:"Generate Q&A",s:"Based on the content in this image, generate 5 practice questions with detailed answers."},
    {id:"solve",l:"Solve / Analyze",s:"If this image contains a math problem, equation, or diagram, solve it step by step. Show all working."},
