    </div>
    {loading&&<div style={{textAlign:"center",padding:40}}><Thinking/></div>}
    {cards.length>0&&card&&<div style={{flex:1,display:"flex",flexDirection:"column"}}>
      <div style={{display:"flex",justifyContent:"space-between",marginBottom:12}}>
        <span style={{fontSize:12,color:T.muted,fontFamily:"'JetBrains Mono',monospace"}}>{idx+1}/{cards.length}</span>
        <div style={{display:"flex",alignItems:"center",gap:8}}>
          <div style={{width:80,height:3,background:T.bg3,borderRadius:2}}><div style={{width:`${pct}%`,height:"100%",background:T.green,borderRadius:2,transition:"width .3s"}}/></div>
          <span style={{fontSize:11,color:T.muted}}>{pct}% known</span>
        </div>
      </div>
      <div onClick={()=>setFlipped(f=>!f)} style={{flex:1,maxHeight:260,minHeight:180,background:T.bg2,border:`1px solid ${flipped?T.amber:T.border}`,borderRadius:10,padding:"2rem",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",cursor:"pointer",textAlign:"center",transition:"border-color .3s"}}>
        <span style={{fontSize:10,fontFamily:"'JetBrains Mono',monospace",color:T.muted,marginBottom:14,letterSpacing:"0.08em",textTransform:"uppercase"}}>{flipped?"answer":"question — click to flip"}</span>
