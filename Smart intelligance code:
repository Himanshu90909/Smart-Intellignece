  {id:"summary",l:"Summary",s:"You are StudyAI. Write a tight revision summary: 1-line definition, 5 key bullets, a Remember: tip. Under 200 words."},
];
function ChatPane({ onSave }) {
  const [msgs,setMsgs]=useState([]);
