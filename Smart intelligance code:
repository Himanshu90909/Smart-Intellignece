              <p style={{fontSize:12,color:T.muted,textAlign:"center",lineHeight:1.5}}>Click or drag & drop<br/>photo or screenshot</p>
            </>
          )}
          <input ref={fileRef} type="file" accept="image/*" onChange={onFile} style={{display:"none"}}/>
        </div>
        {preview&&<>
          <div style={{display:"flex",flexDirection:"column",gap:4}}>
            {SMODES.map(m=>(
              <button key={m.id} onClick={()=>setMode(m.id)} style={{padding:"7px 10px",borderRadius:6,background:mode===m.id?T.bg3:"transparent",border:`1px solid ${mode===m.id?T.border2:"transparent"}`,color:mode===m.id?T.amber:T.muted,fontSize:12,textAlign:"left"}}>
