        <Ico name="quiz" size={28} color={T.muted2}/>
        <p style={{marginTop:12,fontSize:14}}>6-question AI quiz on any topic</p>
        <div style={{display:"flex",flexWrap:"wrap",gap:6,justifyContent:"center",marginTop:12}}>
          {["Solar system","World capitals","Chemistry","Python","History"].map(t=><button key={t} onClick={()=>setTopic(t)} style={{fontSize:12,padding:"4px 10px",borderRadius:5,border:`1px solid ${T.border}`,background:T.bg2,color:T.muted}}>{t}</button>)}
        </div>
      </div>}
    </>}
    {done&&<div style={{overflowY:"auto"}}>
      <div style={{textAlign:"center",padding:"20px 0 16px"}}>
        <p style={{fontSize:36,marginBottom:6}}>{score>=5?"🎉":score>=3?"👍":"📚"}</p>
        <h2 style={{fontSize:20,fontWeight:600,fontFamily:"'Crimson Pro',serif",color:T.amber}}>{score}/{qs.length} correct</h2>
        <p style={{color:T.muted,fontSize:13,marginTop:4,marginBottom:20}}>{score>=5?"Excellent!":score>=3?"Good effort!":"Keep studying!"}</p>
      </div>
      {qs.map((q,i)=>{const a=ans[i];const ok=a?.selected===q.answer;return(
        <div key={i} style={{padding:"10px 14px",borderRadius:8,background:T.bg2,border:`1px solid ${ok?T.green:T.red}22`,marginBottom:8}}>
          <div style={{display:"flex",gap:8,alignItems:"flex-start"}}>
            <span style={{color:ok?T.green:T.red,flexShrink:0,fontSize:13}}>{ok?"✓":"✗"}</span>
            <div>
              <p style={{margin:"0 0 4px",fontSize:13,fontWeight:500,color:T.cream}}>{q.q}</p>
              {!ok&&<p style={{margin:"0 0 2px",fontSize:12,color:T.red}}>Your: {q.options[a?.selected]}</p>}
              <p style={{margin:"0 0 2px",fontSize:12,color:T.green}}>Correct: {q.options[q.answer]}</p>
              <p style={{margin:0,fontSize:12,color:T.muted}}>{q.explanation}</p>
            </div>
          </div>
        </div>
      );})}
      <button onClick={()=>{setQs([]);setDone(false);setTopic("");}} style={{fontSize:13,padding:"8px 20px",border:`1px solid ${T.border}`,borderRadius:7,color:T.muted,marginTop:12}}>New Quiz</button>
    </div>}
    {qs.length>0&&!done&&q&&<div style={{flex:1,display:"flex",flexDirection:"column"}}>
      <div style={{display:"flex",justifyContent:"space-between",marginBottom:14}}>
        <span style={{fontSize:11,color:T.muted,fontFamily:"'JetBrains Mono',monospace"}}>Q{cur+1}/{qs.length}</span>
        <div style={{width:120,height:2,background:T.bg3,borderRadius:1,alignSelf:"center"}}><div style={{width:`${(cur/qs.length)*100}%`,height:"100%",background:T.amber,borderRadius:1,transition:"width .3s"}}/></div>
      </div>
      <p style={{fontSize:16,fontWeight:500,fontFamily:"'Crimson Pro',serif",margin:"0 0 16px",lineHeight:1.5,color:T.cream}}>{q.q}</p>
      <div style={{display:"flex",flexDirection:"column",gap:8,flex:1}}>
        {q.options.map((opt,i)=>{
          let bg=T.bg2,border=`1px solid ${T.border}`,col=T.muted;
          if(sel!==null){if(i===q.answer){bg=T.bg3;border=`1px solid ${T.green}`;col=T.green;}else if(i===sel&&sel!==q.answer){bg=T.bg3;border=`1px solid ${T.red}`;col=T.red;}}
          return <button key={i} onClick={()=>choose(i)} style={{textAlign:"left",padding:"11px 14px",fontSize:14,borderRadius:8,background:bg,border,cursor:sel!==null?"default":"pointer",display:"flex",alignItems:"center",gap:10,color:col}}>
            <span style={{fontSize:11,fontFamily:"'JetBrains Mono',monospace",minWidth:18}}>{["A","B","C","D"][i]}</span>{opt}
          </button>;
        })}
      </div>
      {sel!==null&&<div style={{marginTop:12}}>
        <div style={{padding:"10px 14px",background:T.bg3,borderRadius:8,marginBottom:10,fontSize:13,color:T.muted,border:`1px solid ${T.border}`}}>
          <strong style={{fontWeight:500,color:T.amber}}>Explanation: </strong>{q.explanation}
        </div>
        <button onClick={next} style={{width:"100%",padding:"10px",fontSize:13,background:T.amberDim,border:`1px solid ${T.amber}`,borderRadius:8,color:T.cream}}>{cur<qs.length-1?"Next →":"See Results →"}</button>
      </div>}
    </div>}
  </div>;
}
/* ─── ROOT APP ───────────────────────────────────────────────────────────── */
